# Backend Configuration
# Copy this file to .env and update values for your machine

# ============================================
# FFmpeg Configuration
# ============================================
# Set this if ffmpeg is installed in a custom location
# Leave empty to auto-detect from system PATH
# Windows example: C:\ffmpeg\bin\ffmpeg.exe
# Mac/Linux example: /usr/local/bin/ffmpeg
FFMPEG_PATH=

# ============================================
# API Server Configuration
# ============================================
# Host to bind the FastAPI server to
# 0.0.0.0 = accessible from any IP (for cloud deployment)
# 127.0.0.1 = only local (default, most secure)
API_HOST=0.0.0.0

# Port for the FastAPI server
# Default: 8000
# Change if 8000 is already in use on your machine
API_PORT=8000

# ============================================
# How to use this file
# ============================================
# Windows (PowerShell):
#   $env:FFMPEG_PATH = "C:\path\to\ffmpeg.exe"
#   $env:API_HOST = "0.0.0.0"
#   $env:API_PORT = "8000"

# Windows (Command Prompt):
#   set FFMPEG_PATH=C:\path\to\ffmpeg.exe
#   set API_HOST=0.0.0.0
#   set API_PORT=8000

# Mac/Linux (Bash/Zsh):
#   export FFMPEG_PATH=/path/to/ffmpeg
#   export API_HOST=0.0.0.0
#   export API_PORT=8000
